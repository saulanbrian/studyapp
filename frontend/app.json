{
  "expo": {
    "name": "Cut D' Crop",
    "slug": "cut-d-crop",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/new-icon.png",
    "scheme": "cutdcrop",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.saulanbrian.cutdcrop",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "react-native-edge-to-edge",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/new-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps._some_id_here_"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f43539bf-dbf1-482f-81ad-aa8bae672aa7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "briansaulan05",
    "updates": {
      "url": "https://u.expo.dev/f43539bf-dbf1-482f-81ad-aa8bae672aa7"
    }
  }
}
